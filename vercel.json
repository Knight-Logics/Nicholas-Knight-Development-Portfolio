{
  "build": {
    "env": {
      "NODEJS_HELPERS": "0"
    }
  },
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/pricing",
      "destination": "/pricing.html"
    },
    {
      "source": "/contact",
      "destination": "/contact.html"
    },
    {
      "source": "/book-consultation",
      "destination": "/book-consultation.html"
    },
    {
      "source": "/service-websites",
      "destination": "/service-websites.html"
    },
    {
      "source": "/service-ecommerce",
      "destination": "/service-ecommerce.html"
    },
    {
      "source": "/service-ai-automation",
      "destination": "/service-ai-automation.html"
    },
    {
      "source": "/service-desktop-apps",
      "destination": "/service-desktop-apps.html"
    },
    {
      "source": "/case-study-jns",
      "destination": "/case-study-jns.html"
    },
    {
      "source": "/case-study-knight-group",
      "destination": "/case-study-knight-group.html"
    },
    {
      "source": "/case-study-knight-logics",
      "destination": "/case-study-knight-logics.html"
    },
    {
      "source": "/case-study-farrell-electric",
      "destination": "/case-study-farrell-electric.html"
    },
    {
      "source": "/case-study-sals-painting",
      "destination": "/case-study-sals-painting.html"
    },
    {
      "source": "/case-study-moms-resin-tables",
      "destination": "/case-study-moms-resin-tables.html"
    },
    {
      "source": "/case-study-screen-team",
      "destination": "/case-study-screen-team.html"
    },
    {
      "source": "/display-control-plus",
      "destination": "/display-control-plus.html"
    },
    {
      "source": "/videoforge",
      "destination": "/videoforge.html"
    },
    {
      "source": "/pixelforge-ai",
      "destination": "/pixelforge-ai.html"
    },
    {
      "source": "/auto-vid-compiler",
      "destination": "/auto-vid-compiler.html"
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy-policy.html"
    },
    {
      "source": "/terms-of-service",
      "destination": "/terms-of-service.html"
    },
    {
      "source": "/cookie-policy",
      "destination": "/cookie-policy.html"
    },
    {
      "source": "/refund-policy",
      "destination": "/refund-policy.html"
    },
    {
      "source": "/disclaimer",
      "destination": "/disclaimer.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), usb=(), payment=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/Testimonials/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.webp",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/style\\.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/script\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    }
  ]
}
